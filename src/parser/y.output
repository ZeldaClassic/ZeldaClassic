  108 ScriptTypeDef: SCRIPT TYPEDEF Script_Type IDENTIFIER

  109 Data: DataType Data_List

  110 Data_List: Data_List COMMA Data_Element
  111          | Data_Element

  112 Data_Element: Data_Element_Array_List ASSIGN Expression
  113             | Data_Element_Array_List

  114 Data_Element_Array_List: Data_Element_Array_List Data_Element_Array_Element
  115                        | Identifier

  116 Single_Data_req_assign: DataType Identifier ASSIGN Expression

  117 Data_Element_Array_Element: LBRACKET Data_Element_Array_Element_Size_List RBRACKET
  118                           | LBRACKET RBRACKET

  119 Data_Element_Array_Element_Size_List: Data_Element_Array_Element_Size_List COMMA Expression_Constant
  120                                     | Expression_Constant

  121 Function: STATIC Function
  122         | INLINE Function
  123         | DataType Function_Typeless

  124 Function_Typeless: Function_Heading Statement_Block
  125                  | Function_Heading SEMICOLON
  126                  | Function_Heading COLON DEFAULT Expression_Constant SEMICOLON

  127 Function_Heading: Identifier_List LPAREN Function_Parameters_List RPAREN

  128 Function_Parameters_List: Function_Parameters_Element COMMA Function_Parameters_List
  129                         | Function_Parameters_Element
  130                         | Function_OptParams_List
  131                         | Function_VarArg_Element
  132                         | %empty

  133 Function_Parameters_Element: DataType Identifier

  134 Function_Parameters_Bracket_Element: DataType LBRACKET RBRACKET Identifier

  135 Function_OptParams_List: Function_Parameters_Element ASSIGN Expression_Constant COMMA Function_OptParams_List
  136                        | Function_Parameters_Element ASSIGN Expression_Constant

  137 Function_VarArg_Element: RANGE Function_Parameters_Bracket_Element

  138 Class: ZCLASS IDENTIFIER Class_Block

  139 Class_Block: LBRACE Class_Block_List RBRACE
  140            | LBRACE RBRACE

  141 Class_Block_List: Class_Block_List Class_Block_Element
  142                 | Class_Block_List Option
  143                 | Class_Block_List Class_Constructor
  144                 | Class_Block_List Class_Destructor
  145                 | Class_Block_Element
  146                 | Option
  147                 | Class_Constructor
  148                 | Class_Destructor

  149 Class_Constructor: Function_Typeless

  150 Class_Destructor: BITNOT Function_Typeless

  151 Class_Block_Element: Data SEMICOLON
  152                    | Function
  153                    | DataTypeDef SEMICOLON
  154                    | DataEnum SEMICOLON
  155                    | Using SEMICOLON
  156                    | Statement_Assert SEMICOLON
  157                    | EXPECTERROR LPAREN Expression_Constant RPAREN Class_Block_Element

  158 Annotated_Script: Annotation_List Script

  159 Script: Script_Type SCRIPT IDENTIFIER Script_Block
  160       | SCRIPTSTRUCT IDENTIFIER Script_Block

  161 Script_Type: GLOBAL
  162            | FFC
  163            | ITEMCLASS
  164            | EWEAPON
  165            | LWEAPON
  166            | NPC
  167            | SCREEN
  168            | DMAP
