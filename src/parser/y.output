  172            | SUBSCREENDATA
  173            | GENERIC
  174            | COMBO
  175            | IDENTIFIER

  176 Script_Block: LBRACE Script_Block_List RBRACE
  177             | LBRACE RBRACE

  178 Script_Block_List: Script_Block_List Script_Block_Element
  179                  | Script_Block_List Option
  180                  | Script_Block_Element
  181                  | Option

  182 Script_Block_Element: Data SEMICOLON
  183                     | Function
  184                     | DataTypeDef SEMICOLON
  185                     | DataEnum SEMICOLON
  186                     | Using SEMICOLON
  187                     | Statement_Assert SEMICOLON
  188                     | EXPECTERROR LPAREN Expression_Constant RPAREN Script_Block_Element

  189 Annotation_List: Annotation_List COMMA Annotation
  190                | Annotation

  191 Annotation: HANDLE IDENTIFIER LPAREN QuotedString RPAREN
  192           | HANDLE IDENTIFIER LPAREN NUMBER RPAREN
  193           | HANDLE IDENTIFIER LPAREN LONGNUMBER RPAREN
  194           | HANDLE IDENTIFIER LPAREN MINUS NUMBER RPAREN
  195           | HANDLE IDENTIFIER LPAREN MINUS LONGNUMBER RPAREN

  196 Block_Statement: Statement

  197 Statement: Data SEMICOLON
  198          | DataTypeDef SEMICOLON
  199          | DataEnum SEMICOLON
  200          | Using SEMICOLON
  201          | Expression SEMICOLON
  202          | Statement_Block
  203          | Statement_If
  204          | Statement_Switch
  205          | Statement_For
  206          | Statement_While
  207          | Statement_Do
  208          | Statement_Repeat
  209          | Statement_Return SEMICOLON
  210          | BREAK SEMICOLON
  211          | BREAK NUMBER SEMICOLON
  212          | CONTINUE SEMICOLON
  213          | CONTINUE NUMBER SEMICOLON
  214          | SEMICOLON
  215          | Statement_CompileError SEMICOLON
  216          | Statement_Assert SEMICOLON

  217 Statement_NoSemicolon: Data
  218                      | DataTypeDef
  219                      | DataEnum
  220                      | Expression
  221                      | Statement_Block
  222                      | Statement_If
  223                      | Statement_Switch
  224                      | Statement_For
  225                      | Statement_While
  226                      | Statement_Do
  227                      | Statement_Return
  228                      | BREAK
  229                      | BREAK NUMBER
  230                      | CONTINUE
  231                      | CONTINUE NUMBER
  232                      | %empty
  233                      | Statement_CompileError

  234 Statement_Block: LBRACE Statement_Block_List RBRACE
  235                | LBRACE RBRACE

  236 Statement_Block_List: Statement_Block_List Statement
  237                     | Statement_Block_List Option
  238                     | Statement
  239                     | Option

  240 Statement_If: IF If_Body
  241             | UNLESS If_Body

  242 If_Body: LPAREN Single_Data_req_assign RPAREN Block_Statement
  243        | LPAREN Single_Data_req_assign RPAREN Block_Statement ELSE Block_Statement
  244        | LPAREN Expression RPAREN Block_Statement
  245        | LPAREN Expression RPAREN Block_Statement ELSE Block_Statement

  246 Statement_Switch: SWITCH LPAREN Expression RPAREN LBRACE Statement_Switch_Body RBRACE

  247 Statement_Switch_Body: Statement_Switch_Body Statement_Switch_Cases Statement_Block_List
  248                      | Statement_Switch_Cases Statement_Block_List

  249 Statement_Switch_Cases: Statement_Switch_Cases CASE Expression_Constant COLON
  250                       | Statement_Switch_Cases DEFAULT COLON
  251                       | Statement_Switch_Cases CASE Expression_Range COLON
  252                       | Statement_Switch_Cases CASE CASESTRING COLON
  253                       | CASE Expression_Constant COLON
  254                       | CASE Expression_Range COLON
  255                       | CASE CASESTRING COLON
  256                       | DEFAULT COLON

  257 Statement_For: Statement_For_Standard
  258              | Statement_For_Each

  259 Statement_For_Standard: FOR LPAREN Statement_NoSemicolon SEMICOLON Expression SEMICOLON Statement_NoSemicolon RPAREN Block_Statement
  260                       | FOR LPAREN Statement_NoSemicolon SEMICOLON Expression SEMICOLON Statement_NoSemicolon RPAREN Block_Statement ELSE Block_Statement

  261 Statement_For_Each: FOR LPAREN Identifier Token_In Expression RPAREN Block_Statement
  262                   | FOR LPAREN Identifier Token_In Expression RPAREN Block_Statement ELSE Block_Statement

  263 Token_In: COLON
  264         | IN

  265 Statement_While: WHILE LPAREN Expression RPAREN Block_Statement
  266                | WHILE LPAREN Expression RPAREN Block_Statement ELSE Block_Statement
  267                | UNTIL LPAREN Expression RPAREN Block_Statement
  268                | UNTIL LPAREN Expression RPAREN Block_Statement ELSE Block_Statement

  269 Statement_Do: DO Block_Statement WHILE LPAREN Expression RPAREN
  270             | DO Block_Statement WHILE LPAREN Expression RPAREN ELSE Block_Statement
  271             | DO Block_Statement UNTIL LPAREN Expression RPAREN
  272             | DO Block_Statement UNTIL LPAREN Expression RPAREN ELSE Block_Statement

  273 Statement_Repeat: REPEAT LPAREN Expression_Constant RPAREN Statement

  274 Statement_Return: RETURN Expression
  275                 | RETURN

  276 Statement_CompileError: EXPECTERROR LPAREN Expression_Constant RPAREN Statement_NoSemicolon

  277 DataEnum: ENUM LBRACE Enum_Block RBRACE

  278 Enum_Block: Enum_Block COMMA Data_Element
  279           | Data_Element

  280 Identifier_List: Mixed_Identifier_List
  281                | idlist_scopres
  282                | idlist_dot
  283                | Ambigious_Iden_List

